# GDAL and GEOS library paths for GeoDjango (macOS Homebrew example)
GDAL_LIBRARY_PATH=/opt/homebrew/lib/libgdal.dylib
GEOS_LIBRARY_PATH=/opt/homebrew/lib/libgeos_c.dylib

# Django settings
DJANGO_SETTINGS_MODULE=fuelroute.settings

# Google Geocoding API key — required for address geocoding
GOOGLE_API_KEY=your-google-api-key-here

# Database (optional — defaults to localhost)
# POSTGRES_DB=fuelroute
# POSTGRES_USER=fuelroute
# POSTGRES_PASSWORD=fuelroute
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Cache (optional — defaults to local memory)
# CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
# CACHE_LOCATION=unique-snowflake

# Django secret key — generate a new one for production
# SECRET_KEY=your-secret-key-here
